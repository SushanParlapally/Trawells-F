# Staging Environment Configuration
VITE_API_BASE_URL=https://staging-api.traveldesk.com/api
VITE_APP_ENV=staging

# File Upload Configuration
VITE_UPLOAD_MAX_SIZE=10485760
VITE_SUPPORTED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx

# Debug Configuration
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=warn

# Monitoring Configuration
VITE_MONITORING_ENDPOINT=https://staging-monitoring.traveldesk.com/api/events
VITE_APP_VERSION=1.0.0-staging
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_PERFORMANCE_SAMPLE_RATE=0.5